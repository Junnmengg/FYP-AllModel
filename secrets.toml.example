# .streamlit/secrets.toml.example
# Instructions: 
# 1. Create a folder named '.streamlit' in the project root.
# 2. Copy this file into that folder and rename it to 'secrets.toml'.
# 3. Replace the placeholder values below with your actual credentials.
# 4. NEVER commit the actual 'secrets.toml' file to GitHub.

USERNAME1 = "your_first_username_here"
USERNAME2 = "your_second_username_here"
USERNAME3 = "your_third_username_here"
USERNAME4 = "your_fourth_username_here"
TOKEN = "your_huggingface_token_here"